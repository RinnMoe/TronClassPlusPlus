{
  "manifest_version": 3,
  "name": "TronClass++",
  "version": "2.0.0",
  "description": "TronClass 功能增强插件，支持课件下载和视频播放辅助。",
  "permissions": [
    "downloads",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "*://*/course/*/learning-activity*",
    "https://api.github.com/*",
    "https://raw.githubusercontent.com/RinnMoe/TronClassFileDownloadEnhancer/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*/course/*/learning-activity*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["video-bridge.js"],
      "matches": ["<all_urls>"]
    }
  ]
}

